@startuml restaurant-orders
title Use Case Diagram - Restaurant Order Management (Release 1 / MVP)

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "Restaurant Partner" as A_Restaurant
actor "Push Provider\n(APNs/FCM)" as A_Push
actor "Timer/Scheduler" as A_Timer

rectangle "Food Delivery System (MVP)" as SYS {
  usecase "UC-30 Manage Menu Items" as UC30
  usecase "UC-31 Control Availability\n(Item/Restaurant)" as UC31

  usecase "UC-32 Accept/Reject Incoming Orders" as UC32
  usecase "UC-33 Update Preparation Status\n(Preparing/Ready)" as UC33
  usecase "UC-34 Cancel Order with Reason" as UC34

  usecase "UC-35 New Order Alert" as UC35

  usecase "UC-36 Acknowledge New Order Alert" as UC36
  usecase "UC-37 Expire Unaccepted Order\n(Accept Timeout)" as UC37
  usecase "UC-38 Enforce Order Lifecycle Integrity\n(BR-7)" as UC38
  usecase "UC-39 View Incoming Order Details" as UC39
}

A_Restaurant -- UC30
A_Restaurant -- UC31
A_Restaurant -- UC32
A_Restaurant -- UC33
A_Restaurant -- UC34

A_Push -- UC35
A_Timer -- UC37

UC35 .> UC32 : <<extend>>\n[new order routed]
UC37 .> UC32 : <<extend>>\n[accept timeout exceeded]

UC36 .> UC32 : <<extend>>\n[alert active]
UC32 .> UC39 : <<include>>
UC32 .> UC38 : <<include>>
UC33 .> UC38 : <<include>>
UC34 .> UC38 : <<include>>

@enduml
